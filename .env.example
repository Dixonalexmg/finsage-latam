# Required for real recommendations
GEMINI_API_KEY=

# Optional observability
LOGFIRE_TOKEN=

# UI -> API wiring
FINSAGE_API_URL=http://127.0.0.1:8000
FINSAGE_CORS_ALLOW_ORIGINS=http://localhost:8501
FINSAGE_MAX_REQUEST_SIZE_BYTES=16384

# API defaults
FINSAGE_API_HOST=127.0.0.1
FINSAGE_API_PORT=8000

# Public service port (used by Railway / Streamlit combined deploy)
PORT=8501
